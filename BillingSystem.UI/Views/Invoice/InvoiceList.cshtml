@model IEnumerable<BillingSystem.Dataa.Models.Domain.Invoice>

@{
    ViewData["Title"] = "Invoice List";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Invoice List</h5>
            <a asp-action="Invoice" class="btn btn-light btn-sm">
                New Invoice
            </a>
        </div>
        <div class="card-body">
            <!-- DevExtreme Grid -->
            <div id="invoiceListGrid"></div>
        </div>
    </div>
</div>



@section Scripts {
    <script src="~/js/invoicelist.js"></script>
}


