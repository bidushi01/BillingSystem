@model BillingSystem.Dataa.Models.Domain.Product?

<input type="hidden" id="productId" value="@(Model?.ProductId ?? 0)" />

<div id="Validationsummary"></div>

<div class="mb-2">
    <label class="form-label">Product Code</label>
    <div id="txtProductCode" data-value="@(Model?.ProductCode ?? "")"></div>
</div>

<div class="mb-2">
    <label class="form-label">Product Name</label>
    <div id="txtProductName" data-value="@(Model?.Name ?? "")"></div>
</div>

<div class="mb-2">
    <label class="form-label">Rate</label>
    <div id="txtRate" data-value="@(Model?.Rate ?? 0)"></div>
</div>

<div class="mb-2">
    <label class="form-label">Is Taxable</label>
    <div id="chkIsTaxable" data-value="@(Model?.IsTaxable ?? false)"></div>
</div>

<div class="mb-2">
    <label class="form-label">Status</label>
    <div id="chkStatus" data-value="@(Model?.Status ?? true)"></div>
</div>

<div class="mt-3">
    <button id="btnSave" class="btn btn-success">Save</button>
</div>
